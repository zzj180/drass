# Drass LangChain Compliance Assistant Environment Configuration
# Copy this file to .env and update with your actual values

# ====================
# LLM Configuration
# ====================
# Option 1: OpenRouter (Recommended for quick start)
LLM_PROVIDER=openrouter
LLM_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Option 2: OpenAI
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4-turbo-preview
# OPENAI_API_KEY=your_openai_api_key_here

# Option 3: Local vLLM
# LLM_PROVIDER=vllm
# LLM_MODEL=meta-llama/Llama-2-70b-chat-hf
# VLLM_API_URL=http://localhost:8001

# ====================
# Embedding Configuration
# ====================
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=${OPENAI_API_KEY:-your_embedding_api_key_here}

# Alternative: Local embedding
# EMBEDDING_PROVIDER=sentence-transformers
# EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# ====================
# Reranking Configuration
# ====================
RERANKING_ENABLED=false
RERANKING_PROVIDER=cohere
RERANKING_MODEL=rerank-english-v2.0
RERANKING_API_KEY=your_cohere_api_key_here

# ====================
# Vector Store Configuration
# ====================
VECTOR_STORE_TYPE=chromadb
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Alternative: Weaviate
# VECTOR_STORE_TYPE=weaviate
# WEAVIATE_URL=http://localhost:8080
# WEAVIATE_API_KEY=

# ====================
# Database Configuration
# ====================
DATABASE_URL=postgresql://dify:dify_password@localhost:5432/dify
DB_PASSWORD=dify_password

# ====================
# Redis Configuration
# ====================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ====================
# Security Configuration
# ====================
SECRET_KEY=your-secret-key-here-change-in-production
ENCRYPTION_KEY=your-encryption-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=${SECRET_KEY}
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ====================
# API Configuration
# ====================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true
API_LOG_LEVEL=info

# ====================
# Frontend Configuration
# ====================
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_APP_NAME=Drass Compliance Assistant

# ====================
# Dify Platform Configuration
# ====================
DIFY_PLATFORM_URL=http://localhost
DIFY_API_KEY=your_dify_api_key_here
DIFY_WORKSPACE_ID=your_workspace_id_here

# ====================
# External Services
# ====================
# GitHub Integration
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=your_github_owner_here

# Figma Integration
FIGMA_ACCESS_TOKEN=your_figma_token_here

# ====================
# Feature Flags
# ====================
ENABLE_STREAMING=true
ENABLE_AGENT=true
ENABLE_MEMORY=true
ENABLE_CACHE=true

# ====================
# Performance Configuration
# ====================
MAX_TOKENS=4096
TEMPERATURE=0.7
TOP_P=0.95
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_RETRIES=3
TIMEOUT_SECONDS=30

# ====================
# Storage Configuration
# ====================
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=pdf,docx,xlsx,pptx,txt,md

# ====================
# Monitoring Configuration
# ====================
ENABLE_METRICS=true
METRICS_PORT=9090
LOG_LEVEL=info
LOG_FORMAT=json

# ====================
# Development Settings
# ====================
ENVIRONMENT=development
DEBUG=true
TESTING=false