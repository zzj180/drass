# Environment configuration for Ubuntu with vLLM services
# This file should be copied to /home/qwkj/drass/services/main-app/.env

# API Configuration
APP_NAME="Drass Compliance Assistant"
ENVIRONMENT="production"
DEBUG=false
LOG_LEVEL="INFO"

# Server Configuration
HOST="0.0.0.0"
PORT=8888

# Database
DATABASE_URL="postgresql://drass_user:drass_password@localhost:5432/drass_production"
DB_ECHO=false

# Redis
REDIS_URL="redis://localhost:6379/0"

# Security
SECRET_KEY="change-this-to-a-secure-random-string-in-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS="http://localhost:5173,http://localhost:8888"

# LLM Configuration - Using local vLLM service
LLM_PROVIDER="openai"  # vLLM provides OpenAI-compatible API
LLM_MODEL="vllm"  # Model name served by vLLM
LLM_API_KEY="123456"  # API key configured in vLLM
LLM_BASE_URL="http://localhost:8001/v1"  # vLLM service endpoint
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60

# Alternative LLM Configuration (if needed)
OPENAI_API_BASE="http://localhost:8001/v1"
OPENAI_API_KEY="123456"
OPENAI_MODEL="vllm"

# Embedding Configuration - Using vLLM embedding service
EMBEDDING_PROVIDER="openai"  # vLLM provides OpenAI-compatible API
EMBEDDING_MODEL="Qwen3-Embedding-8B"
EMBEDDING_API_KEY="123456"
EMBEDDING_API_BASE="http://localhost:8010/v1"
EMBEDDING_DIMENSION=1024

# Reranking Configuration - Using vLLM reranking service
RERANKING_ENABLED=true
RERANKING_PROVIDER="custom"
RERANKING_MODEL="Qwen3-Reranker-8B"
RERANKING_API_KEY="123456"
RERANKING_API_BASE="http://localhost:8012/v1"

# Vector Store Configuration
VECTOR_STORE_TYPE="chroma"
CHROMA_HOST="localhost"
CHROMA_PORT=8005
CHROMA_PERSIST_DIRECTORY="/home/qwkj/drass/data/chromadb"
COLLECTION_NAME="drass_documents"

# Document Processing
MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=200
ENABLE_OCR=false
SUPPORTED_FILE_TYPES="pdf,txt,docx,md"

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# File Upload
UPLOAD_DIR="/home/qwkj/drass/data/uploads"
MAX_FILE_SIZE=52428800  # 50MB

# Cache
CACHE_ENABLED=true
CACHE_TTL=3600

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Feature Flags
ENABLE_STREAMING=true
ENABLE_AGENT=true
ENABLE_MEMORY=true
ENABLE_TOOLS=true

# Proxy Configuration (disable for local services)
NO_PROXY="localhost,127.0.0.1,::1,0.0.0.0"

# Disable telemetry for privacy
ANONYMIZED_TELEMETRY=false
DO_NOT_TRACK=true