# Docker Compose override for development environment
# This file extends the base docker-compose.yml with development-specific settings

services:
  # Override main application for development
  api:
    profiles: []  # Remove profile restriction for development
    environment:
      - ENVIRONMENT=development
      - DEBUG=true
      - LOG_LEVEL=DEBUG
      - SQLALCHEMY_DATABASE_URI=postgresql://dify:dev_password@db:5432/dify
      - DB_USERNAME=dify
      - DB_PASSWORD=dev_password
      - DB_HOST=db
      - DB_PORT=5432
      - DB_DATABASE=dify
      - REDIS_HOST=redis
      - REDIS_PORT=6379
      - REDIS_PASSWORD=redis_password_secure_123
      - REDIS_DB=0
      - CELERY_BROKER_URL=redis://:redis_password_secure_123@redis:6379/1
      - CELERY_RESULT_BACKEND=redis://:redis_password_secure_123@redis:6379/1
    volumes:
      - ./config:/app/config:ro
      - ./apps:/app/apps:ro
      - ./templates:/app/templates:ro
      - ./scripts:/app/scripts:ro
      - ./logs:/app/logs
      - ./.env:/app/.env:ro
    ports:
      - "5001:5001"  # Expose API port for development
    stdin_open: true
    tty: true

  # Web service with exposed port
  web:
    ports:
      - "3000:3000"  # Expose web port for development

  # Development database with exposed ports
  db:
    ports:
      - "5432:5432"
    environment:
      - POSTGRES_PASSWORD=dev_password
    volumes:
      - postgres_dev_data:/var/lib/postgresql/data
      - ./config/database/init.sql:/docker-entrypoint-initdb.d/init.sql:ro

  # Development Redis
  redis:
    ports:
      - "6379:6379"
    command: redis-server --appendonly yes --requirepass redis_password_secure_123
    volumes:
      - redis_dev_data:/data

  # Override worker service for development
  worker:
    profiles: []  # Remove profile restriction for development
    environment:
      - ENVIRONMENT=development
      - DEBUG=true
      - LOG_LEVEL=DEBUG
      - SQLALCHEMY_DATABASE_URI=postgresql://dify:dev_password@db:5432/dify
      - DB_USERNAME=dify
      - DB_PASSWORD=dev_password
      - DB_HOST=db
      - DB_PORT=5432
      - DB_DATABASE=dify
      - REDIS_HOST=redis
      - REDIS_PORT=6379
      - REDIS_PASSWORD=redis_password_secure_123
      - REDIS_DB=0
      - CELERY_BROKER_URL=redis://:redis_password_secure_123@redis:6379/1
      - CELERY_RESULT_BACKEND=redis://:redis_password_secure_123@redis:6379/1

  # Development monitoring (optional)
  prometheus:
    profiles: []  # Enable monitoring in development
    ports:
      - "9090:9090"

  grafana:
    profiles: []  # Enable Grafana in development
    ports:
      - "3000:3000"
    environment:
      - GF_SECURITY_ADMIN_PASSWORD=admin

volumes:
  postgres_dev_data:
    driver: local
  redis_dev_data:
    driver: local
