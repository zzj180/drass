# Reranking Service Configuration

# Service Settings
HOST=0.0.0.0
PORT=8002
DEBUG=false

# Model Settings
MODEL_NAME=BAAI/bge-reranker-large
MODEL_CACHE_DIR=./models
DEVICE=cpu  # Options: cuda, cpu, mps (for Apple Silicon)

# Performance Settings
MAX_LENGTH=512
BATCH_SIZE=32
DEFAULT_TOP_K=10
MAX_DOCUMENTS=100

# Cache Settings
CACHE_ENABLED=true
CACHE_TTL=3600
# REDIS_URL=redis://localhost:6379  # Optional: for distributed caching

# Monitoring
ENABLE_METRICS=true

# CORS
CORS_ORIGINS=["*"]