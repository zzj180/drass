# LM Studio MLX Model Configuration
# Qwen3-8B-MLX-bf16 for Apple Silicon
# Generated for Drass LangChain Compliance Assistant

# ====================
# LLM Configuration (LM Studio with MLX)
# ====================
LLM_PROVIDER=openai  # LM Studio uses OpenAI-compatible API
LLM_MODEL=qwen3-8b-mlx-bf16
LLM_API_KEY=not-required  # LM Studio doesn't require API key
LLM_BASE_URL=http://localhost:1234/v1
OPENAI_API_BASE=http://localhost:1234/v1

# Model Parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TOP_P=0.9
LLM_CONTEXT_LENGTH=32768
MODEL_PRECISION=bfloat16  # bf16 precision for quality

# MLX Optimization Settings
USE_MLX=true
USE_METAL=true
METAL_DEVICE=default
MAX_BATCH_SIZE=8
USE_CACHE=true

# LM Studio Settings
LMSTUDIO_HOST=localhost
LMSTUDIO_PORT=1234

# Performance Settings (MLX Optimized)
GPU_LAYERS=-1  # Use all Metal GPU layers
BATCH_SIZE=512
USE_MLOCK=false  # Not needed with MLX
USE_MMAP=true
OFFLOAD_KQV=true  # Offload to GPU
METAL_THREADS=0  # Auto-detect

# ====================
# Embedding Configuration (Local)
# ====================
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=BAAI/bge-base-zh-v1.5
EMBEDDING_SERVICE_URL=http://localhost:8002
EMBEDDING_DIMENSIONS=768
EMBEDDING_BATCH_SIZE=32

# ====================
# Vector Store Configuration
# ====================
VECTOR_STORE_TYPE=chromadb
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_SERVER_HOST=localhost
CHROMA_SERVER_PORT=8000

# ====================
# Database Configuration
# ====================
DATABASE_URL=postgresql://postgres:password@localhost:5432/compliance_db
REDIS_URL=redis://localhost:6379/0

# ====================
# Security Configuration
# ====================
SECRET_KEY=your-secret-key-here-change-in-production
ENCRYPTION_KEY=your-encryption-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=${SECRET_KEY}
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ====================
# API Configuration
# ====================
HOST=0.0.0.0
PORT=8000
WORKERS=4
API_RELOAD=true
LOG_LEVEL=info
ENVIRONMENT=development
DEBUG=true

# ====================
# Frontend Configuration
# ====================
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_APP_NAME=Drass Compliance Assistant

# ====================
# Feature Flags
# ====================
ENABLE_STREAMING=true
ENABLE_AGENT=true
ENABLE_MEMORY=true
ENABLE_TOOLS=true
ENABLE_METRICS=true
RERANKING_ENABLED=false

# ====================
# Performance Settings
# ====================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_RETRIES=3
TIMEOUT_SECONDS=60

# ====================
# Storage Configuration
# ====================
STORAGE_TYPE=local
STORAGE_PATH=./data/uploads
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,docx,xlsx,pptx,txt,md,csv,json